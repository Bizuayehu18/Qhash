# Example environment configuration for QHash.
# Copy this file to .env.local and fill in real values for local development.
# This template contains placeholders only — never put real secrets here.

# --- Frontend-safe Supabase public values ---
# These VITE_ variables are exposed to the browser bundle and are safe to be public.
# VITE_SUPABASE_URL is your Supabase project URL.
# VITE_SUPABASE_ANON_KEY is the public anon key (safe to expose to the client).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server-only secrets ---
# SUPABASE_SERVICE_ROLE_KEY is a secret. It must ONLY be set in the
# Netlify/server environment and must never be exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# TELEBIRR_VERIFIER_API_KEY is a secret. It must ONLY be set in the
# Netlify/server environment and must never be exposed to the browser.
TELEBIRR_VERIFIER_API_KEY=

# Reminder: never commit .env or .env.local with real values.
